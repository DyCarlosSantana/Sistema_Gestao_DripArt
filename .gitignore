# ═══════════════════════════════════════════════════════════
#  .gitignore — DripArt Sistema de Gestão
#  Protege dados sensíveis e arquivos gerados automaticamente
# ═══════════════════════════════════════════════════════════

# ─── Banco de Dados (NUNCA versionar dados reais) ───────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─── Backups locais ─────────────────────────────────────────
backups/

# ─── PDFs Gerados pelo Sistema ──────────────────────────────
docs/

# ─── Python — bytecode e caches ─────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
.Python
*.egg
*.egg-info/
build/
.eggs/

# ─── Ambientes virtuais Python ──────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Variáveis de ambiente ──────────────────────────────────
.env
.env.*
!.env.example

# ─── Node / Vite / npm ──────────────────────────────────────
node_modules/
decor-venue-flow-main/node_modules/
decor-venue-flow-main/dist/
decor-venue-flow-main/.vite/
decor-venue-flow-main/vite.config.ts.timestamp*
decor-venue-flow-main/bun.lock
decor-venue-flow-main/bun.lockb

# ─── Arquivos de build legados (raiz) ───────────────────────
index.html

# ─── Sistema Operacional ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDEs e Editores ────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/

# ─── Testes e Coverage ──────────────────────────────────────
coverage/
htmlcov/
.coverage
.pytest_cache/
